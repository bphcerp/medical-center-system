# ================================================================
# Environment Variables
# ================================================================
# Copy this file to .env and fill in the values.
#
# This file serves two purposes:
#   1. Provides secrets when running "bun dev" locally (without Docker)
#   2. Provides port/config values for docker-compose.yml interpolation
#
# When running inside Docker with the dev profile, application
# secrets come from Vault (not from this file).

TZ=Asia/Kolkata
NODE_ENV=development

# --- Database ---
DB_HOST=localhost
PGUSER=your_db_user
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name
PGPORT=5432

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
VITE_FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-string

# --- SeaweedFS ---
SEAWEEDFS_MASTER=http://localhost:9333
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080

# --- Email ---
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# --- Vault (docker-compose port mapping only) ---
VAULT_PORT=8200